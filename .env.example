# ============================================
# API Configuration
# ============================================

# Базовый URL тестируемого API
# Для Petstore Swagger (стандартный)
BASE_URL=https://petstore.swagger.io/v2

# Если используешь локальный мок-сервер
# BASE_URL=http://localhost:8080/api/v3


# ============================================
# Timeouts (секунды)
# ============================================

# Таймаут соединения
CONNECTION_TIMEOUT=10

# Таймаут чтения ответа
READ_TIMEOUT=10


# ============================================
# Logging
# ============================================

# Логировать запросы (True/False)
LOG_REQUESTS=True

# Логировать ответы (True/False)
LOG_RESPONSES=True

# Уровень логирования (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO


# ============================================
# Test Configuration
# ============================================

# Таймаут выполнения теста (секунды)
TEST_TIMEOUT=30

# Количество параллельных воркеров (для pytest-xdist)
PARALLEL_WORKERS=4

# Рандомное seed для воспроизводимости
RANDOM_SEED=42


# ============================================
# Authentication (если понадобится)
# ============================================

# API Key для аутентификации
# API_KEY=special-key

# OAuth2 токен (если нужен)
# OAUTH_TOKEN=your_token_here


# ============================================
# Environment
# ============================================

# Окружение: dev, test, staging, prod
ENVIRONMENT=test

# Отключить SSL проверку (только для тестов!)
VERIFY_SSL=True